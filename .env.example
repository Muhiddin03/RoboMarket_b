# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL (Railway avtomatik beradi) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Frontend URL (CORS uchun) ────────────────────────────────────────────────
# Lokal:
FRONTEND_URL=http://localhost:3000
# Production (Vercel URL):
# FRONTEND_URL=https://your-site.vercel.app

# ── Admin parol ─────────────────────────────────────────────────────────────
# Birinchi marta ishga tushirishdan keyin:
#   curl -X POST http://localhost:5000/api/auth/setup -H "Content-Type: application/json" -d '{"password":"sizning_parol"}'
# Javobdan "hash" qiymatini quyiga joylashtiring:
ADMIN_PASSWORD_HASH=

# JWT token (kamida 32 ta belgi, tasodifiy):
JWT_SECRET=change-this-to-a-very-long-random-secret-at-least-32-chars

# ── ImageKit.io (rasm saqlash) ───────────────────────────────────────────────
# https://imagekit.io → Dashboard → Developer Options → API Keys
IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxxxxxxxxxx
# Dashboard → URL-endpoint:
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
